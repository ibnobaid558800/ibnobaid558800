<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>واحة رمضان | التصميم الملكي</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/dist/css/all.min.css">
    <style>
        :root {
            --deep-green: #14362a;
            --deep-red: #581010;
            --gold-touch: #c5a059;
            --soft-white: #fdfaf5;
        }
        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--soft-white);
            background-image: radial-gradient(circle at top right, #1a4d3c10 0%, transparent 40%),
                              radial-gradient(circle at bottom left, #58101010 0%, transparent 40%);
        }
        .royal-gradient {
            background: linear-gradient(135deg, var(--deep-green) 0%, var(--deep-red) 100%);
        }
        .ramadan-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.07);
            border: 1px solid rgba(197, 160, 89, 0.2);
            overflow: hidden;
        }
        .btn-option {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 2px solid #f0f0f0;
        }
        .correct-answer {
            background-color: #27ae60 !important;
            color: white !important;
            border-color: #1e8449 !important;
            transform: scale(1.02);
            box-shadow: 0 5px 15px rgba(39, 174, 96, 0.3);
        }
        .wrong-answer {
            background-color: #c0392b !important;
            color: white !important;
            border-color: #922b21 !important;
            transform: scale(0.98);
        }
        .tasbih-sphere {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, var(--deep-green), #0a1f18);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3), inset -5px -5px 15px rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: 4px solid var(--gold-touch);
        }
        .tasbih-sphere:active {
            transform: scale(0.92);
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: var(--gold-touch);
            border-radius: 10px;
        }
    </style>
</head>
<body class="min-h-screen">

    <!-- Header -->
    <header class="royal-gradient text-white py-8 shadow-2xl relative">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-bold mb-2 flex justify-center items-center gap-4">
                <i class="fas fa-mosque text-yellow-500"></i>
                واحة رمضان المبارك
            </h1>
            <p class="text-yellow-200 opacity-90 text-lg">بين الخشوع والمعرفة والتسبيح</p>
        </div>
        <!-- Decorative Border -->
        <div class="absolute bottom-0 left-0 w-full h-1 bg-yellow-600 opacity-50"></div>
    </header>

    <main class="container mx-auto px-4 py-10">
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- Quiz Column -->
            <div class="lg:col-span-8">
                <div class="ramadan-card p-8">
                    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
                        <h2 class="text-2xl font-bold text-emerald-900 border-r-4 border-red-800 pr-4">مسابقة الـ 30 سؤالاً</h2>
                        <div class="flex gap-3">
                            <span id="score" class="bg-red-50 text-red-900 px-5 py-2 rounded-full font-bold border border-red-100">النقاط: 0</span>
                            <span id="progress" class="bg-emerald-50 text-emerald-900 px-5 py-2 rounded-full font-bold border border-emerald-100">السؤال: 1/30</span>
                        </div>
                    </div>

                    <div id="quiz-box">
                        <div class="bg-gray-50 p-6 rounded-2xl mb-8">
                            <h3 id="question-text" class="text-xl md:text-2xl font-bold text-gray-800 leading-relaxed">جاري تحميل الأسئلة...</h3>
                        </div>
                        
                        <div id="options-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <!-- Options load here -->
                        </div>

                        <div id="feedback-area" class="mt-8 hidden p-5 rounded-xl text-center font-bold animate-bounce"></div>
                        
                        <button id="next-btn" onclick="nextQuestion()" class="mt-8 w-full royal-gradient text-white py-4 rounded-2xl font-bold text-xl hidden shadow-lg hover:opacity-90 transition">
                            السؤال التالي <i class="fas fa-arrow-left mr-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-4 space-y-8">
                <!-- Tasbih -->
                <div class="ramadan-card p-8 text-center flex flex-col items-center">
                    <h3 class="text-xl font-bold text-red-900 mb-6 underline decoration-yellow-500 underline-offset-8">المسبحة الملكية</h3>
                    <div class="tasbih-sphere text-white mb-6" onclick="handleTasbih()">
                        <span id="tasbih-count" class="text-5xl font-bold">0</span>
                    </div>
                    <p id="dhikr-text" class="text-emerald-900 font-bold text-xl mb-6">سبحان الله</p>
                    <div class="flex gap-2 w-full">
                        <button onclick="resetTasbih()" class="flex-1 bg-gray-100 py-2 rounded-lg text-gray-600 hover:bg-gray-200 transition">تصفير</button>
                        <button onclick="changeDhikr()" class="flex-2 bg-emerald-50 text-emerald-900 py-2 px-4 rounded-lg font-bold border border-emerald-200">الذكر التالي</button>
                    </div>
                </div>

                <!-- Daily Wisdom -->
                <div class="ramadan-card p-6 bg-emerald-900 text-white">
                    <h3 class="font-bold text-yellow-400 mb-4 flex items-center">
                        <i class="fas fa-lightbulb ml-2"></i> حكمة اليوم
                    </h3>
                    <p class="italic leading-relaxed opacity-90">"الصوم ليس مجرد امتناع عن الطعام، بل هو ارتقاء بالروح وتدريب للنفس على التقوى والصبر."</p>
                </div>
            </div>
        </div>

    </main>

    <footer class="royal-gradient text-white py-12 mt-20 relative overflow-hidden">
        <div class="container mx-auto px-4 text-center">
            <div class="mb-6 text-3xl text-yellow-500">✦ ✦ ✦</div>
            <p class="text-xl font-light mb-4">واحة رمضان | طريقك للعبادة والمعرفة</p>
            <p class="text-sm opacity-60">جميع الحقوق محفوظة © 2024</p>
        </div>
    </footer>

    <script>
        // 30 Questions Integrated
        const quizData = [
            { q: "من هو النبي الذي لُقب بـ 'ذو النون'؟", options: ["يوسف عليه السلام", "يونس عليه السلام", "أيوب عليه السلام", "هود عليه السلام"], correct: 1 },
            { q: "ما هي السورة التي تعدل ثلث القرآن؟", options: ["الفاتحة", "الإخلاص", "الكرسي", "يس"], correct: 1 },
            { q: "من هو النبي الذي كلم الله تعالى تكليماً؟", options: ["إبراهيم عليه السلام", "موسى عليه السلام", "عيسى عليه السلام", "محمد صلى الله عليه وسلم"], correct: 1 },
            { q: "كم عدد سور القرآن الكريم؟", options: ["110 سورة", "114 سورة", "120 سورة", "100 سورة"], correct: 1 },
            { q: "ما هي أطول سورة في القرآن الكريم؟", options: ["آل عمران", "البقرة", "النساء", "المائدة"], correct: 1 },
            { q: "من هو النبي الذي بنى السفينة؟", options: ["نوح عليه السلام", "آدم عليه السلام", "لوط عليه السلام", "شعيب عليه السلام"], correct: 0 },
            { q: "ما هي السورة التي بدأت بدون 'بسم الله الرحمن الرحيم'؟", options: ["النمل", "التوبة", "الفاتحة", "العلق"], correct: 1 },
            { q: "من هو أصغر الأنبياء عمراً عندما أُوتي الحكم؟", options: ["يوسف عليه السلام", "يحيى عليه السلام", "سليمان عليه السلام", "داود عليه السلام"], correct: 1 },
            { q: "كم عدد أجزاء القرآن الكريم؟", options: ["20 جزءاً", "30 جزءاً", "60 جزءاً", "40 جزءاً"], correct: 1 },
            { q: "ما هي السورة التي تسمى 'بني إسرائيل'؟", options: ["الكهف", "الإسراء", "مريم", "طه"], correct: 1 },
            { q: "ما هي أول هجرة في الإسلام كانت إلى أين؟", options: ["المدينة المنورة", "الحبشة", "الطائف", "اليمن"], correct: 1 },
            { q: "من هو أول من آمن من الرجال؟", options: ["عمر بن الخطاب", "أبو بكر الصديق", "علي بن أبي طالب", "عثمان بن عفان"], correct: 1 },
            { q: "ما اسم ناقة الرسول صلى الله عليه وسلم؟", options: ["القصواء", "العضباء", "الكحلاء", "الجدعاء"], correct: 0 },
            { q: "من هو الصحابي الملقب بـ 'سيف الله المسلول'؟", options: ["حمزة بن عبد المطلب", "خالد بن الوليد", "علي بن أبي طالب", "الزبير بن العوام"], correct: 1 },
            { q: "في أي غزوة كُسرت بيضة الرسول وشُج وجهه؟", options: ["بدر", "أحد", "الخندق", "خيبر"], correct: 1 },
            { q: "من هي الملقبة بـ 'ذات النطاقين'؟", options: ["عائشة بنت أبي بكر", "أسماء بنت أبي بكر", "فاطمة الزهراء", "خديجة بنت خويلد"], correct: 1 },
            { q: "كم كان عمر النبي صلى الله عليه وسلم عندما نزل عليه الوحي؟", options: ["25 سنة", "40 سنة", "33 سنة", "50 سنة"], correct: 1 },
            { q: "من هو الغلام الذي آمن بالنبي وكان أول من آمن من الصبيان؟", options: ["الحسن بن علي", "علي بن أبي طالب", "أسامة بن زيد", "عبد الله بن عباس"], correct: 1 },
            { q: "ما هي الغزوة التي هُزم فيها المشركون بريح باردة؟", options: ["حنين", "الأحزاب/الخندق", "تبوك", "الفتح"], correct: 1 },
            { q: "من هو كليم الله من الصحابة الذي كان يكلمه الله بلا ترجمان؟", options: ["جابر بن عبد الله", "عبد الله بن حرام", "سعد بن معاذ", "طلحة بن عبيد الله"], correct: 1 },
            { q: "ما هي الصلاة التي ليس فيها ركوع ولا سجود؟", options: ["صلاة الاستسقاء", "صلاة الجنازة", "صلاة الكسوف", "صلاة الوتر"], correct: 1 },
            { q: "ما هو الركن الثاني من أركان الإسلام؟", options: ["الشهادتان", "الصلاة", "الزكاة", "الصوم"], correct: 1 },
            { q: "كم عدد ركعات صلاة الفجر؟", options: ["4 ركعات", "ركعتان", "3 ركعات", "ركعة واحدة"], correct: 1 },
            { q: "ما هو الشهر الهجري الذي يأتي بعد رمضان؟", options: ["شعبان", "شوال", "ذو القعدة", "رجب"], correct: 1 },
            { q: "بماذا يُعرف البيت الحرام؟", options: ["المسجد النبوي", "الكعبة المشرفة", "المسجد الأقصى", "مسجد قباء"], correct: 1 },
            { q: "كم مرة ذُكر 'رمضان' في القرآن الكريم؟", options: ["مرة واحدة", "مرتان", "ثلاث مرات", "خمس مرات"], correct: 0 },
            { q: "ما هي القبلة الأولى للمسلمين؟", options: ["مكة المكرمة", "بيت المقدس", "المدينة المنورة", "القيروان"], correct: 1 },
            { q: "من هو أول مؤذن في الإسلام؟", options: ["عمار بن ياسر", "بلال بن رباح", "زيد بن حارثة", "أبو هريرة"], correct: 1 },
            { q: "ما هو أعظم آية في القرآن الكريم؟", options: ["آية الدين", "آية الكرسي", "آخر آية في سورة البقرة", "أول آية في سورة العلق"], correct: 1 },
            { q: "ما هو الحيوان الذي قتله نبي الله سليمان لأنه لم يخبره بمكان بلقيس؟", options: ["الهدهد", "النملة", "لم يقتل أي حيوان", "الذئب"], correct: 2 }
        ];

        let currentIndex = 0;
        let score = 0;
        let canAnswer = true;

        // Init
        function loadQuestion() {
            const currentQ = quizData[currentIndex];
            document.getElementById('question-text').innerText = currentQ.q;
            document.getElementById('progress').innerText = `السؤال: ${currentIndex + 1}/${quizData.length}`;
            
            const optionsGrid = document.getElementById('options-grid');
            optionsGrid.innerHTML = '';
            
            document.getElementById('feedback-area').classList.add('hidden');
            document.getElementById('next-btn').classList.add('hidden');
            canAnswer = true;

            currentQ.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "btn-option bg-white p-5 text-right rounded-xl font-bold text-gray-700 shadow-sm hover:shadow-md";
                btn.innerText = opt;
                btn.onclick = () => selectOption(idx, btn);
                optionsGrid.appendChild(btn);
            });
        }

        function selectOption(idx, btn) {
            if (!canAnswer) return;
            canAnswer = false;

            const correct = quizData[currentIndex].correct;
            const feedback = document.getElementById('feedback-area');
            const btns = document.getElementById('options-grid').children;

            if (idx === correct) {
                btn.classList.add('correct-answer');
                score += 10;
                document.getElementById('score').innerText = `النقاط: ${score}`;
                feedback.innerText = "ما شاء الله! إجابة صحيحة ✨";
                feedback.className = "mt-8 p-5 rounded-xl text-center font-bold bg-green-100 text-green-800 block animate-bounce";
            } else {
                btn.classList.add('wrong-answer');
                btns[correct].classList.add('correct-answer');
                feedback.innerText = "إجابة خاطئة، حاول في السؤال القادم 🌙";
                feedback.className = "mt-8 p-5 rounded-xl text-center font-bold bg-red-100 text-red-800 block";
            }
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function nextQuestion() {
            currentIndex++;
            if (currentIndex < quizData.length) {
                loadQuestion();
            } else {
                showResult();
            }
        }

        function showResult() {
            const quizBox = document.getElementById('quiz-box');
            quizBox.innerHTML = `
                <div class="text-center py-12">
                    <div class="text-6xl mb-6">🏆</div>
                    <h3 class="text-3xl font-bold text-emerald-900 mb-4">أنهيت المسابقة بنجاح!</h3>
                    <p class="text-xl text-gray-600 mb-8">مجموع نقاطك هو: <span class="text-red-700 font-bold">${score} من ${quizData.length * 10}</span></p>
                    <button onclick="location.reload()" class="royal-gradient text-white px-10 py-3 rounded-xl font-bold shadow-lg">إعادة المسابقة</button>
                </div>
            `;
        }

        // Tasbih
        let tCount = 0;
        const adhkar = ["سبحان الله", "الحمد لله", "لا إله إلا الله", "الله أكبر", "أستغفر الله"];
        let dIndex = 0;

        function handleTasbih() {
            tCount++;
            document.getElementById('tasbih-count').innerText = tCount;
            // Sound effect could go here
        }

        function resetTasbih() {
            tCount = 0;
            document.getElementById('tasbih-count').innerText = 0;
        }

        function changeDhikr() {
            dIndex = (dIndex + 1) % adhkar.length;
            document.getElementById('dhikr-text').innerText = adhkar[dIndex];
            resetTasbih();
        }

        window.onload = loadQuestion;
    </script>
</body>
</html>

